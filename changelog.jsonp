    {
      "id": "BUG-SOURCE-CONVERT-001",
      "area": "bug",
      "title": "Offer ordinary trailing code comments during guided comment-to-annotation conversion instead of reporting that no comment exists",
      "status": "done",
      "note": "The scanner records exact UTF-16 ranges for standalone, adjacent and trailing comments with or without delimiter whitespace; strings, nested templates, regex, raw strings, heredocs, YAML scalars, SQL dollar strings, nested/unterminated blocks, BOM and CRLF are covered by regressions."
    },
    {
      "id": "BUG-SOURCE-CONVERT-002",
      "area": "bug",
      "title": "Prevent destructive source-comment conversion from fusing neighboring language tokens",
      "status": "done",
      "note": "Remove is now offered only for lexically proven line-comment ranges. Block comments and documentation blocks remain convertible with Keep, but fail closed for Remove until neighboring-token separation can be proven."
    },
    {
      "id": "BUG-SOURCE-CONVERT-003",
      "area": "bug",
      "title": "Deduplicate repeated same-line source comments bijectively instead of suppressing every equal message",
      "status": "done",
      "note": "Exact import provenance, strong and legacy markers, then line/message fallback each consume at most one matching annotation, so two equal comments on one line remain two independently selectable candidates."
    },
    {
      "id": "BUG-SOURCE-CONVERT-004",
      "area": "bug",
      "title": "Preserve a recoverable representation when conversion rollback rejects or cannot restore the source",
      "status": "done",
      "note": "Compensation now keeps or recreates the destination annotation before strict persistence if source restoration fails. Destructive reverse conversion also requires an exact lossless round trip and uses a collision-resistant marker while retaining legacy-marker compatibility."
    },
    {
      "id": "SOURCE-CONVERT-001",
      "area": "developer-workflow",
      "title": "Convert standalone or trailing source comments, file headers and documentation blocks into selected annotations with an explicit Keep/Remove choice",
      "status": "done",
      "note": "The command previews kind/range, supports multi-selection, batch-deduplicates imports, asks whether the source is copied or moved and makes both resources durable. Remove and bounded native Undo/Redo are limited to proven line-comment ranges; block and documentation comments remain available through lossless Keep."
    },
    {
      "id": "SOURCE-CONVERT-002",
      "area": "developer-workflow",
      "title": "Write selected annotations into language-aware source comments or documentation blocks with an explicit Keep/Remove choice, safe markers and Undo",
      "status": "done",
      "note": "Reverse writing is enabled only for 16 audited single-context language modes and a position proven safe by the standalone lexer. Destructive Remove additionally requires exact message round-trip equivalence, emits a 128-bit collision-resistant OOCI identity while reading legacy markers, protects preambles/directives and preserves source-before-store durability with conservative rollback and native Undo/Redo."
    },
