{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/JacquesGariepy/out-of-code-insights/main/schemas/openapi-profile.schema.json",
    "title": "Out-of-Code Insights constrained OpenAPI generation profile",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "format": "uri-reference"
        },
        "openapiVersion": {
            "description": "3.2.0 enables QUERY operations, querystring parameters, and components.mediaTypes. 3.1.2 is the compatibility projection.",
            "enum": ["3.2.0", "3.1.2"],
            "default": "3.2.0"
        },
        "title": {
            "type": "string"
        },
        "version": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "includeAnnotationCatalog": {
            "type": "boolean",
            "default": true
        },
        "components": {
            "$ref": "#/$defs/components"
        },
        "operations": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/operation"
            }
        }
    },
    "allOf": [
        {
            "if": {
                "required": ["openapiVersion"],
                "properties": {
                    "openapiVersion": {
                        "const": "3.1.2"
                    }
                }
            },
            "then": {
                "properties": {
                    "components": {
                        "not": {
                            "required": ["mediaTypes"]
                        },
                        "properties": {
                            "parameters": {
                                "additionalProperties": {
                                    "not": {
                                        "required": ["in"],
                                        "properties": {
                                            "in": {
                                                "const": "querystring"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "operations": {
                        "items": {
                            "allOf": [
                                {
                                    "not": {
                                        "required": ["method"],
                                        "properties": {
                                            "method": {
                                                "const": "query"
                                            }
                                        }
                                    }
                                },
                                {
                                    "properties": {
                                        "parameters": {
                                            "items": {
                                                "not": {
                                                    "required": ["in"],
                                                    "properties": {
                                                        "in": {
                                                            "const": "querystring"
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    }
                }
            }
        }
    ],
    "$defs": {
        "componentMap": {
            "type": "object",
            "propertyNames": {
                "pattern": "^[a-zA-Z0-9._-]+$"
            },
            "additionalProperties": {
                "type": "object"
            }
        },
        "schemaComponentMap": {
            "type": "object",
            "propertyNames": {
                "pattern": "^[a-zA-Z0-9._-]+$"
            },
            "additionalProperties": {
                "type": ["object", "boolean"]
            }
        },
        "components": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "schemas": {
                    "$ref": "#/$defs/schemaComponentMap"
                },
                "responses": {
                    "type": "object",
                    "propertyNames": {
                        "pattern": "^[a-zA-Z0-9._-]+$"
                    },
                    "additionalProperties": {
                        "$ref": "#/$defs/response"
                    }
                },
                "parameters": {
                    "type": "object",
                    "propertyNames": {
                        "pattern": "^[a-zA-Z0-9._-]+$"
                    },
                    "additionalProperties": {
                        "$ref": "#/$defs/parameter"
                    }
                },
                "examples": {
                    "$ref": "#/$defs/componentMap"
                },
                "requestBodies": {
                    "$ref": "#/$defs/componentMap"
                },
                "headers": {
                    "$ref": "#/$defs/componentMap"
                },
                "securitySchemes": {
                    "$ref": "#/$defs/componentMap"
                },
                "links": {
                    "$ref": "#/$defs/componentMap"
                },
                "callbacks": {
                    "$ref": "#/$defs/componentMap"
                },
                "pathItems": {
                    "$ref": "#/$defs/componentMap"
                },
                "mediaTypes": {
                    "$ref": "#/$defs/componentMap"
                }
            },
            "patternProperties": {
                "^x-": true
            }
        },
        "operation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["annotationId", "path", "method", "operationId", "responses"],
            "properties": {
                "annotationId": {
                    "type": "string",
                    "minLength": 1
                },
                "path": {
                    "type": "string",
                    "pattern": "^/[^?#\\s]*$"
                },
                "method": {
                    "enum": ["get", "put", "post", "delete", "options", "head", "patch", "trace", "query"]
                },
                "operationId": {
                    "type": "string",
                    "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$"
                },
                "summary": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "deprecated": {
                    "type": "boolean"
                },
                "parameters": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/parameter"
                    }
                },
                "requestBody": {
                    "type": "object"
                },
                "responses": {
                    "$ref": "#/$defs/responses"
                },
                "security": {
                    "type": "array",
                    "items": {
                        "type": "object"
                    }
                },
                "extensions": {
                    "type": "object",
                    "propertyNames": {
                        "pattern": "^x-"
                    }
                }
            }
        },
        "responses": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {
                "pattern": "^(default|[1-5](?:[0-9]{2}|XX))$"
            },
            "additionalProperties": {
                "$ref": "#/$defs/response"
            }
        },
        "response": {
            "type": "object",
            "properties": {
                "$ref": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^#/components/"
                },
                "description": {
                    "type": "string"
                }
            },
            "anyOf": [
                {
                    "required": ["$ref"]
                },
                {
                    "required": ["description"]
                }
            ]
        },
        "parameter": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "$ref": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^#/components/parameters/"
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "in": {
                    "enum": ["query", "querystring", "header", "path", "cookie"]
                },
                "description": {
                    "type": "string"
                },
                "required": {
                    "type": "boolean"
                },
                "deprecated": {
                    "type": "boolean"
                },
                "schema": {
                    "type": ["object", "boolean"]
                },
                "content": {
                    "type": "object",
                    "minProperties": 1,
                    "maxProperties": 1,
                    "additionalProperties": {
                        "type": "object"
                    }
                }
            },
            "oneOf": [
                {
                    "required": ["$ref"],
                    "not": {
                        "anyOf": [
                            { "required": ["name"] },
                            { "required": ["in"] },
                            { "required": ["description"] },
                            { "required": ["required"] },
                            { "required": ["deprecated"] },
                            { "required": ["schema"] },
                            { "required": ["content"] }
                        ]
                    }
                },
                {
                    "required": ["name", "in", "schema"],
                    "not": {
                        "anyOf": [
                            { "required": ["$ref"] },
                            { "required": ["content"] },
                            {
                                "required": ["in"],
                                "properties": {
                                    "in": { "const": "querystring" }
                                }
                            }
                        ]
                    }
                },
                {
                    "required": ["name", "in", "content"],
                    "not": {
                        "anyOf": [{ "required": ["$ref"] }, { "required": ["schema"] }]
                    }
                }
            ]
        }
    }
}
