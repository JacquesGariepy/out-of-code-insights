{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/JacquesGariepy/out-of-code-insights/main/schemas/document-template.schema.json",
    "title": "Out-of-Code Insights document template",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaVersion",
        "id",
        "label",
        "description",
        "formats",
        "documents",
        "includeInventory",
        "includeAuthored",
        "apiFolder",
        "guideFile",
        "language"
    ],
    "properties": {
        "$schema": {
            "type": "string",
            "format": "uri-reference"
        },
        "schemaVersion": {
            "const": 1
        },
        "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$",
            "maxLength": 64
        },
        "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
        },
        "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
        },
        "formats": {
            "description": "Modern output profile identifiers. Legacy setting aliases are not valid in new templates.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "enum": ["markdown", "static-site", "wiki", "hosted-wiki", "ordered-wiki", "html", "openapi"]
            }
        },
        "documents": {
            "description": "Technical document families to generate. This explicit selection is required.",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "enum": ["readme", "changelog", "architecture", "adr", "onboarding", "runbook", "reference"]
            }
        },
        "includeInventory": {
            "type": "boolean"
        },
        "includeAuthored": {
            "type": "boolean"
        },
        "apiFolder": {
            "description": "One portable, non-hidden path segment. Windows device names, control characters and trailing dots or spaces are forbidden.",
            "type": "string",
            "pattern": "^(?![. ])(?!.*[. ]$)(?!(?:[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Ll][Oo][Cc][Kk]\\$|[Cc][Oo][Nn][Ii][Nn]\\$|[Cc][Oo][Nn][Oo][Uu][Tt]\\$|[Cc][Oo][Mm][1-9¹²³]|[Ll][Pp][Tt][1-9¹²³])(?:\\.|$))[^\\\\/:*?\"<>|\\u0000-\\u001F\\u007F]+$",
            "maxLength": 64
        },
        "guideFile": {
            "description": "One portable, non-hidden path segment ending in lowercase .md.",
            "type": "string",
            "pattern": "^(?=.+\\.md$)(?![. ])(?!.*[. ]$)(?!(?:[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Ll][Oo][Cc][Kk]\\$|[Cc][Oo][Nn][Ii][Nn]\\$|[Cc][Oo][Nn][Oo][Uu][Tt]\\$|[Cc][Oo][Mm][1-9¹²³]|[Ll][Pp][Tt][1-9¹²³])(?:\\.|$))[^\\\\/:*?\"<>|\\u0000-\\u001F\\u007F]+$",
            "maxLength": 96
        },
        "language": {
            "description": "Canonical language[-Script][-REGION] subset, for example en, fr-CA, zh-Hant or zh-Hant-TW.",
            "type": "string",
            "pattern": "^[a-z]{2,3}(-[A-Z][a-z]{3})?(-([A-Z]{2}|[0-9]{3}))?$",
            "maxLength": 15
        }
    },
    "anyOf": [
        {
            "properties": {
                "includeInventory": {
                    "const": true
                }
            }
        },
        {
            "properties": {
                "includeAuthored": {
                    "const": true
                }
            }
        }
    ]
}
