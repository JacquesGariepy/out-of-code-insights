{
    "compilerOptions": {
        "target": "ES2022",
        "module": "nodenext",
        "lib": ["es2020", "es2020.intl", "dom"],
        "outDir": "out",
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "exclude": ["node_modules", ".vscode-test", "out", "dist", "test-fixtures", "license-server"]
}
