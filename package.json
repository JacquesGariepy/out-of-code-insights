        "@typescript-eslint/parser": "^5.30.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "c8": "^11.0.0",
        "concurrently": "^9.2.1",
        "esbuild": "^0.28.0",
        "eslint": "^8.13.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "prettier": "^3.8.3",
        "terser-webpack-plugin": "^5.3.10",
        "ts-loader": "^9.5.7",
        "typescript": "^5.9.3",
        "webpack": "^5.97.0",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.1.0"
    },
